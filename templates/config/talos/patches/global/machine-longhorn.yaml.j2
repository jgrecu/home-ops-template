machine:
  # Required for Longhorn — loads iSCSI kernel module
  # (iscsi-tools extension is pre-installed via factory.talos.dev schematic)
  kernel:
    modules:
      - name: iscsi_tcp
  kubelet:
    # Bind-mounts /var/lib/longhorn into the kubelet so Longhorn can persist
    # replica data across Talos OS upgrades (Talos root is read-only/ephemeral).
    extraMounts:
      - destination: /var/lib/longhorn
        type: bind
        source: /var/lib/longhorn
        options:
          - bind
          - rshared
          - rw
