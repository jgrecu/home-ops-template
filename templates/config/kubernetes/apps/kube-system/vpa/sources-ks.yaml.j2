---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: vpa-sources
  namespace: flux-system
spec:
  interval: 10m
  path: ./kubernetes/apps/kube-system/vpa/sources
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  wait: true
