---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: snapshot-controller
spec:
  interval: 1h
  chart:
    spec:
      chart: snapshot-controller
      version: 5.0.3
      sourceRef:
        kind: HelmRepository
        name: snapshot-controller
      interval: 1h
  install:
    crds: CreateReplace
  upgrade:
    crds: CreateReplace
  values:
    replicaCount: 1

    # Disable group snapshots - CRD not installed
    args:
      enableVolumeGroupSnapshots: false

    resources:
      limits:
        memory: 128Mi
      requests:
        cpu: 10m
        memory: 32Mi
