---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: forgejo
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/group: Development
    gethomepage.dev/name: Forgejo
    gethomepage.dev/icon: forgejo.png
    gethomepage.dev/description: Self-hosted Git service
    gethomepage.dev/href: https://forgejo.${SECRET_DOMAIN}
spec:
  parentRefs:
    - name: envoy-external
      namespace: network
      sectionName: https
  hostnames:
    - "forgejo.${SECRET_DOMAIN}"
  rules:
    - backendRefs:
        - name: forgejo-http
          port: 3000
