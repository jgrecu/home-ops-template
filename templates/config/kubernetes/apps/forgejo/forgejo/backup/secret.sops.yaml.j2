---
apiVersion: v1
kind: Secret
metadata:
  name: forgejo-data-restic-secret
  namespace: forgejo
type: Opaque
stringData:
  RESTIC_REPOSITORY: s3:http://seaweedfs-filer.storage.svc.cluster.local:8333/volsync-backups/forgejo-data
  RESTIC_PASSWORD: "#{ volsync_restic_password }#"
  AWS_ACCESS_KEY_ID: "#{ volsync_s3_access_key }#"
  AWS_SECRET_ACCESS_KEY: "#{ volsync_s3_secret_key }#"
