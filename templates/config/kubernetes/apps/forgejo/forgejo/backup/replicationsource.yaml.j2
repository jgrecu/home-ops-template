---
apiVersion: volsync.backube/v1alpha1
kind: ReplicationSource
metadata:
  name: forgejo-data-backup
  namespace: forgejo
spec:
  sourcePVC: gitea-shared-storage
  trigger:
    schedule: "0 3 * * *"  # Daily at 3 AM
  restic:
    repository: forgejo-data-restic-secret
    retain:
      daily: 7      # Last week
      weekly: 8     # Last 2 months
      monthly: 6    # Last 6 months
    copyMethod: Snapshot
    storageClassName: longhorn
    volumeSnapshotClassName: longhorn
    capacity: 20Gi
    accessModes:
      - ReadWriteOnce
    pruneIntervalDays: 7
    cacheCapacity: 4Gi
    cacheStorageClassName: longhorn
    cacheAccessModes:
      - ReadWriteOnce
    moverResources:
      limits:
        memory: 2Gi
      requests:
        cpu: 100m
        memory: 1Gi
    moverSecurityContext:
      runAsNonRoot: true
      runAsUser: 65534
      fsGroup: 65534
      seccompProfile:
        type: RuntimeDefault
