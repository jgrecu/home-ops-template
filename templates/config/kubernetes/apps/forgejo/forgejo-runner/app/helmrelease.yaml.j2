---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app forgejo-runner
spec:
  chartRef:
    kind: OCIRepository
    name: forgejo-runner
  interval: 1h
  values:
    controllers:
      forgejo-runner:
        replicas: 1
        strategy: Recreate
        containers:
          app:
            image:
              repository: code.forgejo.org/forgejo/runner
              tag: 12.9.0
            command: ["/bin/sh", "-c"]
            args:
              - |
                # Wait for Docker daemon to be ready
                while ! nc -z localhost 2375; do sleep 1; done
                if [ ! -f /data/.runner ]; then
                  forgejo-runner register \
                    --no-interactive \
                    --instance "$FORGEJO_INSTANCE_URL" \
                    --token "$FORGEJO_RUNNER_REGISTRATION_TOKEN" \
                    --name "$HOSTNAME" \
                    --labels "ubuntu-latest:docker://node:20-bullseye,ubuntu-22.04:docker://node:20-bullseye"
                fi
                forgejo-runner daemon
            env:
              FORGEJO_INSTANCE_URL: "http://forgejo-http.forgejo.svc.cluster.local:3000"
              FORGEJO_RUNNER_REGISTRATION_TOKEN:
                valueFrom:
                  secretKeyRef:
                    name: forgejo-runner-secret
                    key: registration-token
              DOCKER_HOST: tcp://localhost:2375
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
              runAsUser: 1000
              runAsGroup: 1000
            resources:
              requests:
                cpu: 50m
              limits:
                memory: 512Mi
          # Docker-in-Docker sidecar for running containerized jobs
          dind:
            image:
              repository: docker
              tag: 29-dind
            env:
              DOCKER_TLS_CERTDIR: ""  # Disable TLS for localhost communication
            securityContext:
              privileged: true
            resources:
              requests:
                cpu: 100m
              limits:
                memory: 2Gi
        pod:
          securityContext:
            fsGroup: 1000
          annotations:
            secret.reloader.stakater.com/reload: *app
    persistence:
      # Stores runner registration state (.runner file) and config per replica.
      # Each replica registers independently — 2 replicas = 2 concurrent jobs.
      data:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 1Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /data
      # Docker storage for DinD — images, layers, build cache
      docker:
        type: emptyDir
        advancedMounts:
          forgejo-runner:
            dind:
              - path: /var/lib/docker
