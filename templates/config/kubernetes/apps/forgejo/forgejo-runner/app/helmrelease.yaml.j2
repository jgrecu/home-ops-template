---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app forgejo-runner
spec:
  chartRef:
    kind: OCIRepository
    name: forgejo-runner
  interval: 1h
  postRenderers:
    - kustomize:
        patches:
          - patch: |
              - op: replace
                path: /spec/template/spec/serviceAccountName
                value: forgejo-runner
            target:
              kind: Deployment
              name: forgejo-runner
  values:
    defaultPodOptions:
      automountServiceAccountToken: true
    controllers:
      forgejo-runner:
        replicas: 1
        strategy: Recreate
        pod:
          securityContext:
            fsGroup: 1000
            fsGroupChangePolicy: "OnRootMismatch"
          annotations:
            secret.reloader.stakater.com/reload: *app
        containers:
          app:
            image:
              repository: code.forgejo.org/forgejo/runner
              tag: 12.10.1
            command: ["/bin/sh", "-c"]
            args:
              - |
                # Create runner config for Kubernetes backend
                cat > /data/config.yaml <<EOF
                log:
                  level: info
                runner:
                  capacity: 1
                  timeout: 3h
                EOF

                if [ ! -f /data/.runner ]; then
                  forgejo-runner register \
                    --no-interactive \
                    --instance "$FORGEJO_INSTANCE_URL" \
                    --token "$FORGEJO_RUNNER_REGISTRATION_TOKEN" \
                    --name "$HOSTNAME" \
                    --labels "ubuntu-latest:kube://docker.io/node:20-bookworm,ubuntu-22.04:kube://docker.io/node:20-bookworm"
                fi
                forgejo-runner --config /data/config.yaml daemon
            env:
              FORGEJO_INSTANCE_URL: "http://forgejo-http.forgejo.svc.cluster.local:3000"
              FORGEJO_RUNNER_REGISTRATION_TOKEN:
                valueFrom:
                  secretKeyRef:
                    name: forgejo-runner-secret
                    key: registration-token
              KUBERNETES_NAMESPACE: "forgejo"
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
              runAsUser: 1000
              runAsGroup: 1000
            resources:
              requests:
                cpu: 20m
                memory: 256Mi
              limits:
                memory: 2Gi
    persistence:
      # Stores runner registration state (.runner file) and config per replica.
      # Each replica registers independently — 2 replicas = 2 concurrent jobs.
      data:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 1Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /data
