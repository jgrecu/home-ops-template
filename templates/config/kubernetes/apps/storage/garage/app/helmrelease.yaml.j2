---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app garage
spec:
  chartRef:
    kind: OCIRepository
    name: garage
  interval: 1h
  values:
    controllers:
      garage:
        # StatefulSet gives a stable pod name (garage-0) needed for the
        # bootstrap commands in ks.yaml. The stable hostname also means
        # Longhorn and CNPG always resolve garage.storage.svc.cluster.local
        # to the same node after pod restarts.
        type: statefulset
        containers:
          app:
            image:
              repository: dxflrs/garage
              tag: v2.3.0
            env:
              GARAGE_CONFIG_FILE: /etc/garage/garage.toml
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /health
                    port: 3903
                  initialDelaySeconds: 60
                  periodSeconds: 30
                  timeoutSeconds: 5
                  failureThreshold: 10
              readiness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /health
                    port: 3903
                  initialDelaySeconds: 30
                  periodSeconds: 10
                  failureThreshold: 10
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
              readOnlyRootFilesystem: true
            resources:
              requests:
                cpu: 15m
              limits:
                memory: 256Mi
        pod:
          annotations:
            secret.reloader.stakater.com/reload: *app

    persistence:
      # Cluster metadata: node layout, bucket configs, key index, object index.
      # Small (2Gi is plenty), latency-sensitive — Longhorn is ideal.
      meta:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 2Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /meta

      # Object data: the actual content of every S3 object stored in Garage.
      # Lives on the NAS — large capacity, already part of your backup strategy.
      # The NAS share root is mounted directly (no subDir) so any pre-existing
      # data is accessible immediately. reclaimPolicy: Retain ensures deleting
      # the PVC never deletes NAS files.
      data:
        type: persistentVolumeClaim
        storageClass: nfs-garage
        size: 1Ti
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /data

      # Garage config (garage.toml) from the SOPS secret.
      # Contains the admin token and RPC secret.
      config:
        type: secret
        name: garage-config
        globalMounts:
          - path: /etc/garage
            readOnly: true

    service:
      # S3 API — used by Longhorn and CNPG to read/write backup objects
      s3:
        ports:
          s3:
            port: &s3Port 3900
      # Admin API — used only during bootstrap and key management
      admin:
        ports:
          admin:
            port: &adminPort 3903

    # Garage is internal-only — no route needed.
    # Longhorn and CNPG connect via ClusterIP: garage.storage.svc.cluster.local:3900
