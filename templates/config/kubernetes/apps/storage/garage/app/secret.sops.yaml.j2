---
# Garage configuration stored as a SOPS secret because it contains the
# admin_token (secures the admin API) and rpc_secret (secures inter-node RPC).
# Both are sensitive values that must not appear in plaintext in Git.
apiVersion: v1
kind: Secret
metadata:
  name: garage-config
stringData:
  garage.toml: |
    metadata_dir = "/meta"
    data_dir = "/data"
    replication_factor = 1

    rpc_bind_addr = "[::]:3901"
    # rpc_secret must be a 32-byte hex string.
    # Generate with: openssl rand -hex 32
    rpc_secret = "#{ garage_rpc_secret }#"

    [s3_api]
    # Region string — apps connecting to Garage must use this exact value.
    # Longhorn and CNPG are configured with "garage" below.
    s3_region = "garage"
    api_bind_addr = "[::]:3900"

    [admin]
    api_bind_addr = "[::]:3903"
    # Used to authenticate garage CLI commands against the admin API.
    # Generate with: openssl rand -base64 32
    admin_token = "#{ garage_admin_token }#"
