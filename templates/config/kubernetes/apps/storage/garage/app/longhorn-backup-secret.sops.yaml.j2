---
# S3 credentials for Longhorn to write volume backups to Garage.
# Leave empty until Step 3 of the Garage bootstrap (see ks.yaml comments).
# Longhorn reads this secret by name from the backup target settings.
apiVersion: v1
kind: Secret
metadata:
  name: longhorn-backup-secret
stringData:
  AWS_ACCESS_KEY_ID: "#{ garage_s3_access_key_id }#"
  AWS_SECRET_ACCESS_KEY: "#{ garage_s3_secret_access_key }#"
  AWS_ENDPOINTS: "http://garage-s3.storage.svc.cluster.local:3900"
  AWS_REGION: "garage"
