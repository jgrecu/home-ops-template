---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: csi-driver-nfs
spec:
  chart:
    spec:
      chart: csi-driver-nfs
      version: 4.13.2
      sourceRef:
        kind: HelmRepository
        name: csi-driver-nfs
  interval: 1h
  values:
    driver:
      mountPermissions: 0
    controller:
      replicas: 1
      resources:
        requests:
          cpu: 10m
        limits:
          memory: 128Mi
    node:
      resources:
        requests:
          cpu: 10m
        limits:
          memory: 128Mi
