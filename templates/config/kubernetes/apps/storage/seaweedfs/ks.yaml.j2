---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: seaweedfs
spec:
  dependsOn:
    - name: longhorn
    - name: csi-driver-nfs
  interval: 1h
  path: ./kubernetes/apps/storage/seaweedfs/app
  postBuild:
    substituteFrom:
      - name: cluster-secrets
        kind: Secret
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  targetNamespace: storage
  # TWO-STEP BOOTSTRAP:
  # SeaweedFS S3 access keys are created after the cluster starts.
  #
  # Step 1 — first deploy (seaweedfs_s3_access_key_id / secret are empty):
  #   task configure --yes && git commit && git push
  #   Wait for SeaweedFS pods to come up.
  #
  # Step 2 — initialise buckets and create S3 credentials:
  #   task storage:bootstrap-seaweedfs
  #
  # Step 3 — credentials are auto-updated in cluster.yaml by the bootstrap script:
  #   task configure --yes && git commit && git push
  #   Flux reconciles — Longhorn and CNPG backup secrets are updated automatically.
  wait: true
