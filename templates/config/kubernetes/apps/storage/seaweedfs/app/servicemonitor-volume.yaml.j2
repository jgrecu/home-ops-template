---
# ServiceMonitor for SeaweedFS Volume metrics
# Scrapes metrics from volume servers (data storage):
# - seaweedfs_volume_size_bytes: Total volume size
# - seaweedfs_volume_read_bytes_total: Total bytes read
# - seaweedfs_volume_write_bytes_total: Total bytes written
# - seaweedfs_volume_disk_free_bytes: Free disk space
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: seaweedfs-volume
  namespace: storage
  labels:
    app.kubernetes.io/name: seaweedfs
    app.kubernetes.io/component: volume
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: seaweedfs
      app.kubernetes.io/component: volume
  endpoints:
    - port: metrics
      interval: 30s
      path: /metrics
