---
apiVersion: v1
kind: Secret
metadata:
  name: seaweedfs-s3-secret
stringData:
  seaweedfs_s3_config: |
    {
      "identities": [
        {
          "name": "admin",
          "credentials": [
            {
              "accessKey": "#{ seaweedfs_s3_access_key_id }#",
              "secretKey": "#{ seaweedfs_s3_secret_access_key }#"
            }
          ],
          "actions": [
            "Admin",
            "Read",
            "Write",
            "List",
            "Tagging"
          ]
        }
      ]
    }
