---
# S3 credentials for Longhorn to write volume backups to SeaweedFS.
# Leave empty until the SeaweedFS bootstrap is complete (see ks.yaml comments).
# Longhorn reads this secret by name from the backup target settings.
apiVersion: v1
kind: Secret
metadata:
  name: longhorn-backup-secret
stringData:
  AWS_ACCESS_KEY_ID: "#{ seaweedfs_s3_access_key_id }#"
  AWS_SECRET_ACCESS_KEY: "#{ seaweedfs_s3_secret_access_key }#"
  AWS_ENDPOINTS: "http://seaweedfs-filer.storage.svc.cluster.local:8333"
  AWS_REGION: "us-east-1"
