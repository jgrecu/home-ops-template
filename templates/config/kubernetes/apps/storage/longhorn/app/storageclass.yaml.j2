---
# Single-replica Longhorn StorageClass — intended for use with CloudNativePG.
# CNPG handles its own replication (primary + standby across different nodes),
# so Longhorn's default 2-replica replication would be redundant and wasteful.
# Using this class gives CNPG: 1 Longhorn replica per instance × 2 CNPG
# instances = 2 total copies of data on 2 different nodes. Correct and efficient.
#
# Do NOT use this for regular apps — use the default `longhorn` class instead.
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: longhorn-single
  annotations:
    storageclass.kubernetes.io/is-default-class: "false"
provisioner: driver.longhorn.io
parameters:
  numberOfReplicas: "1"
  staleReplicaTimeout: "2880"
  dataLocality: "best-effort"
allowVolumeExpansion: true
reclaimPolicy: Retain
volumeBindingMode: Immediate
