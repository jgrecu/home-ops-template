---
# ServiceMonitor for k8s-gateway (CoreDNS) metrics
# Scrapes DNS and CoreDNS metrics:
# - coredns_dns_request_count_total: Total DNS requests by type
# - coredns_dns_response_rcode_count_total: Response codes (NOERROR, NXDOMAIN, etc.)
# - coredns_dns_request_duration_seconds: Request latency histograms
# - coredns_cache_hits_total / coredns_cache_misses_total: Cache effectiveness
# - coredns_forward_request_count_total: Forwarded queries
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: k8s-gateway
  namespace: network
  labels:
    app.kubernetes.io/name: k8s-gateway
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: k8s-gateway
      app.kubernetes.io/service: k8s-gateway-metrics
  endpoints:
    - port: metrics
      interval: 30s
      path: /metrics
