---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app wg-easy
  namespace: network
spec:
  chartRef:
    kind: OCIRepository
    name: wg-easy
  interval: 1h
  values:
    controllers:
      wg-easy:
        initContainers:
          # Set up nftables rules before WireGuard starts
          nftables-setup:
            image:
              repository: alpine
              tag: 3.23
            command:
              - /bin/sh
              - -c
              - |
                apk add --no-cache nftables
                nft add table ip nat
                nft add chain ip nat postrouting { type nat hook postrouting priority 100 \; }
                nft add rule ip nat postrouting oifname "eth0" ip saddr 10.8.0.0/24 masquerade
                nft add table ip filter
                nft add chain ip filter input { type filter hook input priority 0 \; }
                nft add rule ip filter input udp dport 51820 accept
                nft add chain ip filter forward { type filter hook forward priority 0 \; }
                nft add rule ip filter forward iifname "wg0" accept
                nft add rule ip filter forward oifname "wg0" accept
            securityContext:
              privileged: true
        containers:
          app:
            image:
              repository: ghcr.io/wg-easy/wg-easy
              # renovate: datasource=docker depName=ghcr.io/wg-easy/wg-easy
              tag: 15
            env:
              TZ: "Europe/Madrid"
              # Web UI port
              PORT: "51821"
              # Allow HTTP access (behind internal gateway with HTTPS)
              INSECURE: "true"
              # Minimal configuration required for v15
              INIT_ENABLED: "true"
              INIT_USERNAME: "admin"
              INIT_PASSWORD: "testpassword123"
              INIT_HOST: "#{ wg_easy_external_host }#"
              INIT_PORT: "51820"
              INIT_DNS: "#{ pihole_dns_addr }#"
              INIT_IPV4_CIDR: "10.8.0.0/24"
              # Route all traffic through VPN (disable split-tunnel)
              INIT_ALLOWED_IPS: "0.0.0.0/0"
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /
                    port: &webPort 51821
                  initialDelaySeconds: 30
                  periodSeconds: 30
                  timeoutSeconds: 5
                  failureThreshold: 5
              readiness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /
                    port: *webPort
                  initialDelaySeconds: 15
                  periodSeconds: 10
            # WireGuard requires NET_ADMIN and SYS_MODULE capabilities
            # Talos Linux requires privileged mode for these capabilities
            securityContext:
              privileged: true
            resources:
              requests:
                cpu: 10m
                memory: 128Mi
              limits:
                memory: 256Mi

          # WireGuard Interface Manager
          # Monitors and manages wg0 interface since wg-quick fails on Talos (nftables vs iptables)
          # Continuously watches for config changes and reapplies interface settings
          wg-manager:
            image:
              repository: alpine
              tag: 3.23
            command:
              - /bin/sh
              - -c
              - |
                # Install required tools
                apk add --no-cache wireguard-tools iproute2

                echo "WireGuard interface manager starting..."

                # Function to bring up wg0 interface
                bring_up_interface() {
                  echo "Waiting for wg0.conf to be created..."
                  while [ ! -f /etc/wireguard/wg0.conf ]; do
                    sleep 2
                  done

                  echo "Config file found, bringing up interface..."

                  # Remove wg-quick specific directives and create clean config
                  grep -v "^Address\|^MTU\|^PreUp\|^PostUp\|^PreDown\|^PostDown" /etc/wireguard/wg0.conf > /tmp/wg0-stripped.conf

                  # Create WireGuard interface if it doesn't exist
                  if ! ip link show wg0 >/dev/null 2>&1; then
                    ip link add dev wg0 type wireguard
                  fi

                  # Apply WireGuard configuration
                  wg setconf wg0 /tmp/wg0-stripped.conf

                  # Configure interface addresses
                  ip address flush dev wg0 2>/dev/null || true
                  ip address add 10.8.0.1/24 dev wg0
                  ip address add fdcc:ad94:bacf:61a4::cafe:1/112 dev wg0

                  # Set MTU and bring interface up
                  ip link set mtu 1420 up dev wg0

                  echo "WireGuard interface wg0 is UP"
                }

                # Initial interface setup
                bring_up_interface

                # Monitor loop - watch for config changes or interface going down
                last_hash=$(md5sum /etc/wireguard/wg0.conf 2>/dev/null | awk '{print $1}')

                while true; do
                  sleep 10

                  # Check if interface is still up
                  if ! ip link show wg0 up >/dev/null 2>&1; then
                    echo "Interface wg0 is down, bringing it back up..."
                    bring_up_interface
                    continue
                  fi

                  # Check if config file has changed (new peer added/removed)
                  if [ -f /etc/wireguard/wg0.conf ]; then
                    current_hash=$(md5sum /etc/wireguard/wg0.conf | awk '{print $1}')
                    if [ "$current_hash" != "$last_hash" ]; then
                      echo "Config file changed, reloading interface..."
                      bring_up_interface
                      last_hash=$current_hash
                    fi
                  fi
                done
            securityContext:
              privileged: true
            resources:
              requests:
                cpu: 5m
                memory: 32Mi
              limits:
                memory: 64Mi

          # WireGuard Prometheus Exporter
          # Exports detailed VPN metrics: peer count, bandwidth, handshakes, etc.
          metrics:
            image:
              repository: mindflavor/prometheus-wireguard-exporter
              tag: 3.6.6
            args:
              - -a
              - "true"
              - -n
              - /etc/wireguard/wg0.conf
              - -i
              - wg0
            securityContext:
              privileged: true
              runAsUser: 0
              runAsGroup: 0
              capabilities:
                add: ["NET_ADMIN"]
            resources:
              requests:
                cpu: 5m
                memory: 32Mi
              limits:
                memory: 64Mi
        pod:
          annotations:
            secret.reloader.stakater.com/reload: *app
          # Required sysctls for WireGuard routing
          securityContext:
            sysctls:
              - name: net.ipv4.ip_forward
                value: "1"
              - name: net.ipv4.conf.all.src_valid_mark
                value: "1"

    persistence:
      # WireGuard configuration, keys, and peer configs
      config:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 1Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /etc/wireguard

    service:
      # Web UI - internal only
      web:
        controller: wg-easy
        ports:
          http:
            port: *webPort

      # Metrics endpoint for Prometheus
      metrics:
        controller: wg-easy
        ports:
          metrics:
            port: 9586
            protocol: TCP

      # WireGuard VPN - external LoadBalancer
      vpn:
        controller: wg-easy
        type: LoadBalancer
        annotations:
          io.cilium/lb-ipam-ips: "#{ wg_easy_vpn_addr }#"
        externalTrafficPolicy: Cluster
        ports:
          wireguard:
            port: 51820
            protocol: UDP
