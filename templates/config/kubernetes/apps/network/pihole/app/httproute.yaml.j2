---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: pihole
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/name: "Pi-hole"
    gethomepage.dev/group: "Network"
    gethomepage.dev/description: "DNS resolver and ad blocker"
    gethomepage.dev/icon: "pi-hole.png"
    gethomepage.dev/href: "https://pihole.${SECRET_DOMAIN}"
spec:
  hostnames:
    - pihole.${SECRET_DOMAIN}
  parentRefs:
    - name: envoy-internal
      namespace: network
      sectionName: https
  rules:
    - backendRefs:
        - name: pihole-web
          port: 80
