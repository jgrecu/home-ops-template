---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: woodpecker-server
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/group: Development
    gethomepage.dev/name: Woodpecker CI
    gethomepage.dev/icon: woodpecker-ci.png
    gethomepage.dev/description: Lightweight CI/CD platform
    gethomepage.dev/href: https://woodpecker.${SECRET_DOMAIN}
spec:
  parentRefs:
    - name: envoy-external
      namespace: network
      sectionName: https
  hostnames:
    - "woodpecker.${SECRET_DOMAIN}"
  rules:
    - backendRefs:
        - name: woodpecker-server
          port: 8000
