---
# CloudNativePG manages this PostgreSQL instance.
# The operator automatically creates a secret named "woodpecker-postgres-app"
# in this namespace containing: username, password, host, port, dbname, uri.
# Woodpecker's HelmRelease reads the connection string directly from that secret.
apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: woodpecker-postgres
spec:
  # 2 instances = 1 primary + 1 replica for high availability.
  # CNPG operator automatically enables soft pod anti-affinity to spread across nodes.
  # Provides automatic failover and read scaling.
  instances: 2
  resources:
    requests:
      cpu: 250m
      memory: 1Gi
    limits:
      memory: 4Gi
  storage:
    storageClass: longhorn-single
    size: 5Gi
  bootstrap:
    initdb:
      database: woodpecker
      owner: woodpecker
  # Continuous WAL archiving to SeaweedFS S3
  # Provides point-in-time recovery with ~5 minute RPO
  backup:
    barmanObjectStore:
      destinationPath: "s3://cnpg-backups/woodpecker-postgres/"
      endpointURL: "http://seaweedfs-filer.storage.svc.cluster.local:8333"
      s3Credentials:
        accessKeyId:
          name: cnpg-backup-secret
          key: ACCESS_KEY_ID
        secretAccessKey:
          name: cnpg-backup-secret
          key: ACCESS_SECRET_KEY
      wal:
        compression: gzip
    retentionPolicy: "180d"
