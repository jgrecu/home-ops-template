---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: woodpecker-server-backup
  namespace: flux-system
spec:
  interval: 10m
  path: ./kubernetes/apps/woodpecker/woodpecker-server/backup
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  wait: true
  dependsOn:
    - name: volsync
      namespace: storage
    - name: woodpecker-server
