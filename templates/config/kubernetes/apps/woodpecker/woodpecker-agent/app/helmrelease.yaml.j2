---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app woodpecker-agent
spec:
  chartRef:
    kind: OCIRepository
    name: woodpecker-agent
  interval: 1h
  values:
    defaultPodOptions:
      automountServiceAccountToken: true
    controllers:
      woodpecker-agent:
        replicas: 1  # Number of concurrent agent workers
        strategy: Recreate
        containers:
          agent:
            image:
              repository: woodpeckerci/woodpecker-agent
              tag: v3.14.0
            env:
              WOODPECKER_LOG_LEVEL: "debug"
              WOODPECKER_SERVER: "woodpecker-server.woodpecker.svc.cluster.local:9000"
              WOODPECKER_AGENT_SECRET:
                valueFrom:
                  secretKeyRef:
                    name: woodpecker-agent-secret
                    key: agent-secret
              WOODPECKER_BACKEND: "kubernetes"
              WOODPECKER_BACKEND_K8S_NAMESPACE: "woodpecker"
              WOODPECKER_BACKEND_K8S_STORAGE_CLASS: "longhorn"
              WOODPECKER_BACKEND_K8S_STORAGE_RWX: "false"
              WOODPECKER_BACKEND_K8S_VOLUME_SIZE: "256M"
              WOODPECKER_BACKEND_K8S_POD_ANNOTATIONS: ""
              WOODPECKER_BACKEND_K8S_POD_LABELS: ""
              WOODPECKER_MAX_WORKFLOWS: "1"
            probes:
              liveness:
                enabled: false  # Agent crashes on Docker unavailability, liveness would kill it
              readiness:
                enabled: false  # Distroless image has no shell for probes
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
              runAsUser: 1000
              runAsGroup: 1000
              runAsNonRoot: true
            resources:
              requests:
                cpu: 20m
                memory: 256Mi
              limits:
                memory: 2Gi
        pod:
          automountServiceAccountToken: true
          restartPolicy: Always
          securityContext:
            fsGroup: 1000
          annotations:
            secret.reloader.stakater.com/reload: *app
