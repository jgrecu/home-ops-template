---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: woodpecker-agent
spec:
  dependsOn:
    - name: woodpecker-server
  interval: 1h
  path: ./kubernetes/apps/woodpecker/woodpecker-agent/app
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  targetNamespace: woodpecker
  wait: false
