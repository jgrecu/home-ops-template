---
apiVersion: v1
kind: ConfigMap
metadata:
  name: homepage-widgets
data:
  widgets.yaml: |
    ---
    - logo:
        icon: https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/png/kubernetes.png

    - greeting:
        text_size: xl
        text: "Home Lab Dashboard"

    - kubernetes:
        cluster:
          show: true
          cpu: true
          memory: true
          showLabel: true
        nodes:
          show: true
          cpu: true
          memory: true
          showLabel: true

    - search:
        provider: duckduckgo
        target: _blank

    - datetime:
        text_size: l
        format:
          dateStyle: long
          timeStyle: short
          hourCycle: h23
