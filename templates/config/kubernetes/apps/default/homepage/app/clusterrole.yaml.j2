---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: homepage
rules:
  # Read HTTPRoute resources for auto-discovery
  - apiGroups: ["gateway.networking.k8s.io"]
    resources: ["httproutes"]
    verbs: ["get", "list"]

  # Read pods for widget metrics (CPU, memory)
  - apiGroups: [""]
    resources: ["pods", "namespaces"]
    verbs: ["get", "list"]

  # Read nodes for cluster-wide metrics
  - apiGroups: [""]
    resources: ["nodes"]
    verbs: ["get", "list"]

  # Read pod metrics via metrics.k8s.io API
  - apiGroups: ["metrics.k8s.io"]
    resources: ["pods", "nodes"]
    verbs: ["get", "list"]
