---
apiVersion: tuppr.home-operations.com/v1alpha1
kind: KubernetesUpgrade
metadata:
  name: kubernetes
spec:
  kubernetes:
    # renovate: datasource=docker depName=ghcr.io/siderolabs/kubelet
    version: v1.35.4

  healthChecks:
    # Wait for each node to be Ready before proceeding to the next.
    - apiVersion: v1
      kind: Node
      expr: status.conditions.exists(c, c.type == "Ready" && c.status == "True")
      timeout: 10m

  maintenance:
    windows:
      # Same window as Talos upgrades — tuppr sequences OS upgrades before
      # Kubernetes control-plane upgrades automatically.
      - start: "0 2 * * 0"
        duration: "4h"
        timezone: "UTC"
