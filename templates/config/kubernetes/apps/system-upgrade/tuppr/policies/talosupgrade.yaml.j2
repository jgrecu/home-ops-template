---
apiVersion: tuppr.home-operations.com/v1alpha1
kind: TalosUpgrade
metadata:
  name: cluster
spec:
  talos:
    # renovate: datasource=docker depName=ghcr.io/siderolabs/installer
    version: v1.13.0

  policy:
    debug: false
    force: false
    # default reboot mode — graceful shutdown and reboot
    rebootMode: default
    # soft placement — prefers to upgrade non-critical nodes first
    placement: soft
    timeout: 30m

  healthChecks:
    # Wait for each node to report Ready before moving to the next.
    # Prevents a failed upgrade from cascading across all three nodes.
    - apiVersion: v1
      kind: Node
      expr: status.conditions.exists(c, c.type == "Ready" && c.status == "True")
      timeout: 10m

  maintenance:
    windows:
      # Sunday at 02:00 UTC — aligns with the Renovate schedule so version
      # bump PRs merged on the weekend trigger upgrades the same night.
      - start: "0 2 * * 0"
        duration: "4h"
        timezone: "UTC"

  drain:
    deleteLocalData: true
    ignoreDaemonSets: true
    force: true
