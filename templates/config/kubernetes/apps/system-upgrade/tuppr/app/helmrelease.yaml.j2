---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: tuppr
spec:
  chartRef:
    kind: OCIRepository
    name: tuppr
  interval: 1h
  values:
    controller:
      logLevel: info

    # Enable Prometheus scraping — kube-prometheus-stack picks this up
    # automatically via serviceMonitorSelectorNilUsesHelmValues: false
    serviceMonitor:
      enabled: true

    resources:
      requests:
        cpu: 10m
      limits:
        memory: 128Mi
