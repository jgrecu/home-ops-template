---
#% set smartctl_devices = [] %#
#% for node in nodes %#
#%   if '/dev/nvme' in node.disk %#
#%     set device = '/dev/nvme0' %#
#%   elif node.disk.startswith('/dev/sd') %#
#%     set device = '/dev/' ~ node.disk[5:8] %#
#%   else %#
#%     set device = none %#
#%   endif %#
#%   if device and device not in smartctl_devices %#
#%     set _ = smartctl_devices.append(device) %#
#%   endif %#
#% endfor %#
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: smartctl-exporter
spec:
  chartRef:
    kind: OCIRepository
    name: smartctl-exporter
  interval: 1h
  values:
    controllers:
      smartctl-exporter:
        type: daemonset
        containers:
          app:
            image:
              repository: quay.io/prometheuscommunity/smartctl-exporter
              tag: v0.14.0
            args:
              - --smartctl.path=/usr/sbin/smartctl
              - --web.listen-address=:9633
              #% for device in smartctl_devices %#
              - --smartctl.device=#{ device }#
              #% endfor %#
            # smartctl needs privileged access to read raw disk device data
            securityContext:
              privileged: true
              readOnlyRootFilesystem: true
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  tcpSocket:
                    port: &port 9633
                  initialDelaySeconds: 30
                  periodSeconds: 60
                  failureThreshold: 5
              readiness:
                enabled: true
                custom: true
                spec:
                  tcpSocket:
                    port: *port
                  initialDelaySeconds: 10
                  periodSeconds: 30
            resources:
              requests:
                cpu: 20m
                memory: 128Mi
              limits:
                memory: 1Gi
        pod:
          # Need host PID namespace to access SMART data on host block devices
          hostPID: true

    persistence:
      # Mount host /dev so the exporter can see all block devices (sda, nvme0, etc.)
      dev:
        type: hostPath
        hostPath: /dev
        globalMounts:
          - path: /dev

    service:
      app:
        ports:
          metrics:
            port: *port

    # ServiceMonitor tells Prometheus to scrape this exporter automatically.
    # kube-prometheus-stack picks it up because serviceMonitorSelectorNilUsesHelmValues: false.
    serviceMonitor:
      app:
        serviceName: smartctl-exporter
        endpoints:
          - port: metrics
            interval: 5m
            scrapeTimeout: 30s
            path: /metrics
