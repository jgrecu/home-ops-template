---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: &app grafana
spec:
  chartRef:
    kind: OCIRepository
    name: grafana
  interval: 1h
  values:
    admin:
      existingSecret: grafana-secret
      userKey: admin-user
      passwordKey: admin-password

    # Pre-configure Prometheus and Loki as data sources so dashboards
    # work out of the box without any manual UI configuration.
    datasources:
      datasources.yaml:
        apiVersion: 1
        datasources:
          - name: Prometheus
            type: prometheus
            url: http://kube-prometheus-stack-prometheus.observability.svc.cluster.local:9090
            isDefault: true
            jsonData:
              timeInterval: 1m
          - name: Loki
            type: loki
            url: http://loki-gateway.observability.svc.cluster.local:80
            jsonData:
              maxLines: 1000

    # Enable sidecar to watch for ConfigMaps with grafana_dashboard label
    # This adds custom dashboards from ConfigMaps to the existing downloaded ones
    sidecar:
      dashboards:
        enabled: true
        label: grafana_dashboard
        labelValue: "1"
        searchNamespace: ALL
        folderAnnotation: grafana_folder
        folder: /tmp/dashboards
        provider:
          disableDelete: false
          allowUiUpdates: true
          foldersFromFilesStructure: true
      datasources:
        enabled: false

    # Dashboard provider configuration
    # Note: The sidecar container automatically creates "sidecarProvider" for /tmp/dashboards,
    # so we only need to define the "default" provider here to avoid duplicates.
    dashboardProviders:
      dashboardproviders.yaml:
        apiVersion: 1
        providers:
          - name: default
            orgId: 1
            folder: ""
            type: file
            disableDeletion: false
            editable: true
            options:
              path: /var/lib/grafana/dashboards/default

    # All dashboards are now managed via ConfigMaps (see dashboard-*.yaml files)
    # This ensures version control, reproducibility, and consistency with GitOps
    dashboards:
      default: {}

    persistence:
      enabled: true
      storageClassName: longhorn
      size: 1Gi

    # Recreate strategy required: RWO PVC cannot be attached to multiple pods
    deploymentStrategy:
      type: Recreate

    pod:
      annotations:
        secret.reloader.stakater.com/reload: *app

    service:
      type: ClusterIP
      port: 80

    ingress:
      enabled: false

    route:
      main:
        enabled: true
        hostnames: ["grafana.${SECRET_DOMAIN}"]
        parentRefs:
          - name: envoy-internal
            namespace: network
            sectionName: https

    resources:
      requests:
        cpu: 20m
        memory: 128Mi
      limits:
        memory: 1Gi
