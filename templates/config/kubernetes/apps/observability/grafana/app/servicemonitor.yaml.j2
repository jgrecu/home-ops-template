---
# ServiceMonitor for Grafana metrics
# Scrapes metrics from Grafana server:
# - grafana_api_response_status_total: API response status codes
# - grafana_database_queries_total: Database query metrics
# - grafana_stat_totals_dashboard: Dashboard statistics
# - go_* metrics: Go runtime metrics
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: grafana
  namespace: observability
  labels:
    app.kubernetes.io/name: grafana
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: grafana
  endpoints:
    - port: service
      interval: 30s
      path: /metrics
