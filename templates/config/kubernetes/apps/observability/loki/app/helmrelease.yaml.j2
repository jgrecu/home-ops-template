---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: loki
spec:
  chart:
    spec:
      chart: loki
      version: 6.55.0
      sourceRef:
        kind: HelmRepository
        name: loki
  interval: 1h
  values:
    # Single binary mode — one pod handles ingest, query, and compaction.
    # Simpler than the scalable/microservices modes; ideal for a 3-node home lab.
    deploymentMode: SingleBinary

    loki:
      # No multi-tenant auth — all logs go into the "fake" tenant.
      # Set to true and add X-Scope-OrgID headers if you later want tenancy.
      auth_enabled: false

      commonConfig:
        replication_factor: 1

      # Store logs on local filesystem backed by a Longhorn PVC.
      # For production you'd use S3/MinIO, but Longhorn is fine for home lab.
      storage:
        type: filesystem

      schemaConfig:
        configs:
          - from: "2024-01-01"
            store: tsdb
            object_store: filesystem
            schema: v13
            index:
              prefix: loki_index_
              period: 24h

      limits_config:
        # Keep logs for 30 days, then delete automatically
        retention_period: 720h
        # Allow high-cardinality streams from a busy home lab
        ingestion_rate_mb: 16
        ingestion_burst_size_mb: 32

    singleBinary:
      replicas: 1
      persistence:
        storageClass: longhorn
        size: 10Gi
      resources:
        requests:
          cpu: 50m
          memory: 512Mi
        limits:
          memory: 1Gi

    # Disable the components that only make sense in scalable/HA mode
    read:
      replicas: 0
    write:
      replicas: 0
    backend:
      replicas: 0

    # Disable chunksCache and resultsCache to reduce memory footprint
    # on small clusters. Queries will be slightly slower but functional.
    chunksCache:
      enabled: false
      replicas: 0
    resultsCache:
      enabled: false
      replicas: 0
