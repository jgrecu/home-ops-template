---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: goldilocks
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/name: "Goldilocks"
    gethomepage.dev/group: "Observability"
    gethomepage.dev/description: "VPA resource recommendations dashboard"
    gethomepage.dev/icon: "goldilocks.png"
    gethomepage.dev/href: "https://goldilocks.${SECRET_DOMAIN}"
spec:
  parentRefs:
    - name: envoy-internal
      namespace: network
      sectionName: https
  hostnames:
    - "goldilocks.${SECRET_DOMAIN}"
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: goldilocks-dashboard
          port: 80
