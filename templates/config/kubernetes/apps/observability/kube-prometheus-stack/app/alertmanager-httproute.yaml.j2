---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: alertmanager
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/name: "AlertManager"
    gethomepage.dev/group: "Observability"
    gethomepage.dev/description: "Alert routing and grouping"
    gethomepage.dev/icon: "prometheus.png"
    gethomepage.dev/href: "https://alertmanager.${SECRET_DOMAIN}"
spec:
  hostnames:
    - alertmanager.${SECRET_DOMAIN}
  parentRefs:
    - name: envoy-internal
      namespace: network
      sectionName: https
  rules:
    - backendRefs:
        - name: kube-prometheus-stack-alertmanager
          port: 9093
