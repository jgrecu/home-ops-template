---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: kube-prometheus-stack
spec:
  chartRef:
    kind: OCIRepository
    name: kube-prometheus-stack
  interval: 1h
  values:
    crds:
      enabled: true

    # Grafana is deployed separately so we have full control over its config.
    # Disable it here to avoid running two Grafana instances.
    grafana:
      enabled: false

    alertmanager:
      alertmanagerSpec:
        storage:
          volumeClaimTemplate:
            spec:
              storageClassName: longhorn
              accessModes: [ReadWriteOnce]
              resources:
                requests:
                  storage: 1Gi

    prometheus:
      prometheusSpec:
        # Keep 14 days of metrics on disk — adjust if your SSDs fill up
        retention: 14d
        retentionSize: 15GB
        storageSpec:
          volumeClaimTemplate:
            spec:
              storageClassName: longhorn
              accessModes: [ReadWriteOnce]
              resources:
                requests:
                  storage: 20Gi
        # Pick up ALL ServiceMonitors and PodMonitors in the cluster,
        # not just the ones created by this chart. This lets every app
        # add its own monitoring without changing the Prometheus config.
        serviceMonitorSelectorNilUsesHelmValues: false
        podMonitorSelectorNilUsesHelmValues: false
        ruleSelectorNilUsesHelmValues: false
        resources:
          requests:
            cpu: 500m
            memory: 2Gi
          limits:
            memory: 8Gi

    # Disable kube-proxy monitoring (Talos uses Cilium as kube-proxy replacement)
    kubeProxy:
      enabled: false

    # node-exporter runs as a DaemonSet on every node and exposes hardware
    # metrics: CPU, memory, disk I/O, network, filesystem usage.
    nodeExporter:
      enabled: true

    # kube-state-metrics exposes Kubernetes object metrics: pod status,
    # deployment replicas, PVC capacity, node conditions, etc.
    # Also configured to expose Flux CD custom resource metrics for dashboards.
    kube-state-metrics:
      extraArgs:
        - --custom-resource-state-config-file=/etc/customresourcestate/flux.yaml
      volumeMounts:
        - name: customresourcestate-config
          mountPath: /etc/customresourcestate
          readOnly: true
      volumes:
        - name: customresourcestate-config
          configMap:
            name: kube-state-metrics-customresourcestate-config
