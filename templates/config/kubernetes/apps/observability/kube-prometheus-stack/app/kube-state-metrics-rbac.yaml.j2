---
# ClusterRole to allow kube-state-metrics to access Flux CRDs and custom resources
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: kube-state-metrics-flux-resources
rules:
  # Permission to list CRDs (required for custom resource state metrics)
  - apiGroups: ["apiextensions.k8s.io"]
    resources: ["customresourcedefinitions"]
    verbs: ["list", "watch"]
  # Permissions for Flux source.toolkit.fluxcd.io resources
  - apiGroups: ["source.toolkit.fluxcd.io"]
    resources:
      - gitrepositories
      - helmrepositories
      - helmcharts
      - buckets
      - ocirepositories
    verbs: ["list", "watch"]
  # Permissions for Flux kustomize.toolkit.fluxcd.io resources
  - apiGroups: ["kustomize.toolkit.fluxcd.io"]
    resources:
      - kustomizations
    verbs: ["list", "watch"]
  # Permissions for Flux helm.toolkit.fluxcd.io resources
  - apiGroups: ["helm.toolkit.fluxcd.io"]
    resources:
      - helmreleases
    verbs: ["list", "watch"]
---
# ClusterRoleBinding to bind the role to kube-state-metrics ServiceAccount
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: kube-state-metrics-flux-resources
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: kube-state-metrics-flux-resources
subjects:
  - kind: ServiceAccount
    name: kube-prometheus-stack-kube-state-metrics
    namespace: observability
