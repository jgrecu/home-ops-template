---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: home-assistant
spec:
  chartRef:
    kind: OCIRepository
    name: home-assistant
  interval: 1h
  values:
    controllers:
      home-assistant:
        # Recreate — RWO PVC cannot be mounted by two pods simultaneously.
        # HA also does not support running multiple instances.
        strategy: Recreate
        containers:
          app:
            image:
              repository: ghcr.io/home-assistant/home-assistant
              # renovate: datasource=docker depName=ghcr.io/home-assistant/home-assistant
              tag: "2026.4.3"
            env:
              TZ: "Europe/Madrid"
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  # HA's /api/ endpoint requires auth; use tcp probe to avoid
                  # false negatives during startup and token-less health checks
                  tcpSocket:
                    port: &port 8123
                  initialDelaySeconds: 60
                  periodSeconds: 30
                  failureThreshold: 5
              readiness:
                enabled: false
            # HA runs as root — required for certain integrations that open
            # raw sockets or read /proc. Do not drop capabilities.
            securityContext:
              privileged: false
            resources:
              requests:
                cpu: 50m
              limits:
                memory: 1Gi

    persistence:
      # All HA config lives here: configuration.yaml, automations.yaml,
      # scripts, blueprints, custom_components, and the SQLite database.
      config:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 5Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /config

    service:
      app:
        ports:
          http:
            port: *port

    route:
      app:
        hostnames: ["home-assistant.${SECRET_DOMAIN}"]
        parentRefs:
          - name: envoy-internal
            namespace: network
            sectionName: https
        rules:
          - backendRefs:
              - identifier: app
                port: *port
        annotations:
          gethomepage.dev/enabled: "true"
          gethomepage.dev/group: Home Automation
          gethomepage.dev/name: Home Assistant
          gethomepage.dev/icon: home-assistant.png
          gethomepage.dev/description: Smart home automation platform
          gethomepage.dev/href: https://home-assistant.${SECRET_DOMAIN}
