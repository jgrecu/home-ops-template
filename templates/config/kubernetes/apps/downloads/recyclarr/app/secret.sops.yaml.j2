---
# yaml-language-server: $schema=https://kubernetes-schemas.pages.dev/v1/secret.json
apiVersion: v1
kind: Secret
metadata:
  name: recyclarr-secret
stringData:
  # recyclarr.yml — pushed into the container at /config/recyclarr.yml.
  #
  # Customize the quality profiles and custom formats below to match your
  # preferences. The TRaSH Guides (https://trash-guides.info) document every
  # available custom format and recommended profile configuration.
  #
  # API keys are filled in after Radarr/Sonarr are running (see two-step
  # bootstrap note in helmrelease.yaml). Leave as empty strings until then.
  recyclarr.yml: |
    radarr:
      movies:
        base_url: http://radarr.downloads.svc.cluster.local:7878
        api_key: "#{ recyclarr_radarr_api_key }#"
        quality_definition:
          type: movie
        quality_profiles:
          - name: HD-1080p
        custom_formats:
          # Add custom format assignments here.
          # See https://trash-guides.info/Radarr/radarr-setup-quality-profiles/

    sonarr:
      shows:
        base_url: http://sonarr.downloads.svc.cluster.local:8989
        api_key: "#{ recyclarr_sonarr_api_key }#"
        quality_definition:
          type: series
        quality_profiles:
          - name: WEB-1080p
        custom_formats:
          # Add custom format assignments here.
          # See https://trash-guides.info/Sonarr/sonarr-setup-quality-profiles/
