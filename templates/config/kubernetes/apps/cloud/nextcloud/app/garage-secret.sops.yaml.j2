---
# S3 credentials for CNPG (barman-cloud) to write WAL and base backups to Garage.
# Leave empty until Step 3 of the Garage bootstrap (see storage/garage/ks.yaml).
apiVersion: v1
kind: Secret
metadata:
  name: garage-cnpg-secret
stringData:
  ACCESS_KEY_ID: "#{ garage_s3_access_key_id }#"
  ACCESS_SECRET_KEY: "#{ garage_s3_secret_access_key }#"
  AWS_REGION: "garage"
  AWS_ENDPOINT: "http://garage-s3.storage.svc.cluster.local:3900"
