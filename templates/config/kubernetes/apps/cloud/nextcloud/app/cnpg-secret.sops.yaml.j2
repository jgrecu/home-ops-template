---
# S3 credentials for CNPG (barman-cloud) to write WAL and base backups to SeaweedFS.
# Leave empty until SeaweedFS bootstrap is complete (see storage/seaweedfs/ks.yaml).
apiVersion: v1
kind: Secret
metadata:
  name: cnpg-backup-secret
stringData:
  ACCESS_KEY_ID: "#{ seaweedfs_s3_access_key_id }#"
  ACCESS_SECRET_KEY: "#{ seaweedfs_s3_secret_access_key }#"
  AWS_REGION: "us-east-1"
  AWS_ENDPOINT: "http://seaweedfs-filer.storage.svc.cluster.local:8333"
