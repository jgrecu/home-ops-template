---
# PVC for entertainment namespace (Jellyfin)
# Binds to static PV pointing to /videos on NAS
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: media-library
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""  # Empty to use static PV
  volumeName: nfs-media-videos-entertainment  # Bind to entertainment PV
  resources:
    requests:
      storage: 10Ti
