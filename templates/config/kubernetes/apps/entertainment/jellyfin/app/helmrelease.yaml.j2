---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: jellyfin
spec:
  chartRef:
    kind: OCIRepository
    name: jellyfin
  interval: 1h
  values:
    controllers:
      jellyfin:
        pod:
          securityContext:
            # Supplemental group for /dev/dri access (render group GID 44 on Talos)
            supplementalGroups: [44]
        containers:
          app:
            image:
              repository: ghcr.io/jellyfin/jellyfin
              # renovate: datasource=docker depName=ghcr.io/jellyfin/jellyfin
              tag: 10.11.8
            env:
              TZ: "Europe/Madrid"
            probes:
              liveness: &probes
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /health
                    port: &port 8096
                  initialDelaySeconds: 30
                  periodSeconds: 30
              readiness: *probes
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
            resources:
              requests:
                cpu: 15m
                memory: 256Mi
              limits:
                memory: 2Gi

    persistence:
      # Jellyfin config, metadata cache, and transcoding temp on Longhorn.
      # First boot will scan /media and build the library index here.
      config:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 10Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /config

      # Intel GPU device for Quick Sync Video hardware transcoding
      dri:
        type: hostPath
        hostPath: /dev/dri
        globalMounts:
          - path: /dev/dri

      # Media library on NFS — same share that Radarr/Sonarr import into.
      # Your NAS should look like: /videos/Films  /videos/Series
      # Jellyfin will see both folders and can have separate libraries for each.
      # Uses shared static PV pointing to /videos on NAS
      media:
        type: persistentVolumeClaim
        existingClaim: media-library
        globalMounts:
          - path: /media

    service:
      app:
        ports:
          http:
            port: *port

    route:
      app:
        hostnames: ["jellyfin.${SECRET_DOMAIN}"]
        parentRefs:
          - name: envoy-internal
            namespace: network
            sectionName: https
        rules:
          - backendRefs:
              - identifier: app
                port: *port
        annotations:
          gethomepage.dev/enabled: "true"
          gethomepage.dev/group: Entertainment
          gethomepage.dev/name: Jellyfin
          gethomepage.dev/icon: jellyfin.png
          gethomepage.dev/description: Media streaming server
          gethomepage.dev/href: https://jellyfin.${SECRET_DOMAIN}
